# Servidor
PORT=3000
NODE_ENV=development
BACKEND_URL=http://localhost:3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=face_to_work

# JWT
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# CORS / Frontend (separa con coma si tienes varios orígenes)
FRONTEND_URL=http://localhost:5173

# Admin inicial (lo crea `npm run seed`)
ADMIN_EMAIL=admin@facetowork.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrador

# IA de reconocimiento facial — Groq Cloud (https://console.groq.com/keys)
# Compatible con la API de OpenAI; usa un modelo Llama con visión.
GROQ_API_KEY=gsk_tu_api_key_de_groq
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Confianza mínima (0-100) para dar por reconocido a un trabajador
GROQ_MATCH_THRESHOLD=55
