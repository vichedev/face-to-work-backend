# ==========================================================================
#  Face to Work — plantilla del entorno de PRODUCCIÓN
#  Copia este archivo a .env.production y rellena los valores.
# ==========================================================================

# --- Reverse proxy (Caddy) ---
# Sólo IP (servidor de pruebas) -> certificado auto-firmado:
#   SITE_ADDRESS=178.104.217.84
# Con dominio -> certificado real de Let's Encrypt automático:
#   SITE_ADDRESS=asistencia.tudominio.com
SITE_ADDRESS=tu.ip.o.dominio
HTTP_PORT=80
HTTPS_PORT=443

# --- Base de datos PostgreSQL ---
DB_USERNAME=ftw_user
DB_PASSWORD=cambia-esta-clave-fuerte
DB_NAME=face_to_work
DB_SYNC=true

# --- JWT (mínimo 32 caracteres; genera uno con: openssl rand -base64 48) ---
JWT_SECRET=genera-una-cadena-aleatoria-larga-y-secreta
JWT_EXPIRES_IN=7d

# --- URLs públicas (mismo origen para SPA y API) ---
FRONTEND_URL=https://tu.ip.o.dominio
BACKEND_URL=https://tu.ip.o.dominio

# --- Usuario administrador inicial ---
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia-esta-clave
ADMIN_NAME=Administrador

# --- IA de reconocimiento facial (Groq Cloud — https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_tu_api_key_de_groq
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MATCH_THRESHOLD=55
